# Copy to .env and fill in values for local development
# Railway injects these automatically in production

DATABASE_URL=postgresql://user:password@localhost:5432/jlrs
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/jlrs_test

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRY_HOURS=24

FRONTEND_URL=http://localhost:5173

# Used to sign webhook payloads with HMAC-SHA256
WEBHOOK_SECRET=change-this-to-another-long-random-secret

# Protects POST /internal/jobs/* from public access
INTERNAL_JOB_SECRET=change-this-to-yet-another-secret
