# global options
{
    admin off 
    persist_config off 
    auto_https off 
    log {
        format json 
    }
    servers {
        trusted_proxies static private_ranges 100.0.0.0/8 
    }
}

# site block - Railway injects HTTP_PORT or PORT. 
# Using :{$PORT} is correct, but let's make sure Caddy evaluates fallback routing cleanly.
:{$PORT} {
    log {
        format json 
    }

    # Health check rewrite for Railway
    rewrite /health /api/v1/health

    # 1. Handle API requests first
    handle /api/* {
        reverse_proxy 127.0.0.1:8001
    }

    # 2. Handle everything else (React Frontend)
    handle {
        root * /app/dist
        encode gzip
        header +X-Served-By "Caddy-Static"
        
        # Rewrite to index.html if the file or directory doesn't exist
        try_files {path} {path}/ /index.html
        
        # Actually serve the file
        file_server
    }
}