# global options
{
    admin off # there's no need for the admin api in railway's environment
    persist_config off # storage isn't persistent anyway
    auto_https off # railway handles https for us, this would cause issues if left enabled
    # runtime logs
    log {
        format json # set runtime log format to json mode
    }
    # server options
    servers {
        trusted_proxies static private_ranges 100.0.0.0/8 # trust railway's proxy
    }
}

# site block, listens on the $PORT environment variable, automatically assigned by railway
:{$PORT:8000} {
    # access logs
    log {
        format json # set access log format to json mode
    }

    # health check for railway
    rewrite /health /api/v1/health

    # Proxy API requests to the Python backend
    # Adjust this path if your API routes use a different prefix
    handle /api/* {
        reverse_proxy localhost:8001
    }

    # Serve the React app from the 'dist' folder
    handle {
        root * /app/dist
        header +X-Served-By "Caddy-Static"
        encode gzip
        try_files {path} /index.html
        file_server
    }
}